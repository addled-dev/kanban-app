# ── Database ──────────────────────────────────────────────────────
POSTGRES_USER=kanban
POSTGRES_PASSWORD=kanban_secret
POSTGRES_DB=kanban

# ── Next.js auth ───────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change_this_secret_in_production_32chars
NEXTAUTH_URL=http://localhost:3000
APP_URL=http://localhost:3000

# ── Default admin account (seeded on first boot) ───────────────────
ADMIN_EMAIL=admin@kanban.local
ADMIN_PASSWORD=ChangeMe123!
ADMIN_NAME=Admin

# ── Gmail SMTP ─────────────────────────────────────────────────────
# Requires a Google App Password (not your regular password).
# Enable 2FA on the Google account, then:
#   Google Account → Security → 2-Step Verification → App passwords
# Generate an app password for "Mail" and paste it below.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-google-app-password-here
SMTP_FROM=Kanban Board <you@gmail.com>

# ── MCP OAuth2 bearer auth (optional) ───────────────────────────
# If set, MCP endpoints accept Authorization: Bearer <token>
# alongside X-Api-Key. Tokens are validated using issuer/JWKS.
MCP_OAUTH_ISSUER=
MCP_OAUTH_JWKS_URL=
MCP_OAUTH_AUDIENCE=

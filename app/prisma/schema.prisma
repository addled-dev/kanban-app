generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum ProjectRole {
  ADMIN
  READ_WRITE
  VIEW
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum WorkItemType {
  EPIC
  FEATURE
  STORY
  TASK
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String
  name          String?
  role          Role     @default(USER)
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  projects            Project[]
  projectMemberships  ProjectMember[]
  createdTasks        Task[]               @relation("TaskCreator")
  assignedTasks       Task[]               @relation("TaskAssignee")
  passwordResetTokens PasswordResetToken[]
  mcpApiKeys          McpApiKey[]
  mcpOAuthClients     McpOAuthClient[]
  mcpOAuthCodes       McpOAuthAuthorizationCode[]
  mcpOAuthTokens      McpOAuthAccessToken[]
}

model InviteToken {
  id          String       @id @default(cuid())
  email       String
  name        String?
  token       String       @unique
  expiresAt   DateTime
  usedAt      DateTime?
  createdBy   String
  projectId   String?
  projectRole ProjectRole?
  createdAt   DateTime     @default(now())

  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([email])
  @@index([projectId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
}

model McpApiKey {
  id        String    @id @default(cuid())
  userId    String
  name      String
  keyHash   String    @unique
  lastUsed  DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model McpOAuthClient {
  id                  String   @id @default(cuid())
  userId              String?
  name                String
  clientId            String   @unique
  clientSecretHash    String?
  redirectUris        String[]
  tokenEndpointAuthMethod String @default("none")
  lastUsed            DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user         User?                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  codes        McpOAuthAuthorizationCode[]
  accessTokens McpOAuthAccessToken[]

  @@index([userId])
  @@index([clientId])
}

model McpOAuthAuthorizationCode {
  id                  String    @id @default(cuid())
  userId              String
  clientId            String
  codeHash            String    @unique
  redirectUri         String
  codeChallenge       String
  codeChallengeMethod String
  scope               String?
  expiresAt           DateTime
  usedAt              DateTime?
  createdAt           DateTime  @default(now())

  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  client McpOAuthClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([clientId])
  @@index([expiresAt])
}

model McpOAuthAccessToken {
  id        String    @id @default(cuid())
  userId    String
  clientId  String
  tokenHash String    @unique
  scope     String?
  expiresAt DateTime
  lastUsed  DateTime?
  createdAt DateTime  @default(now())

  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  client McpOAuthClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([clientId])
  @@index([expiresAt])
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  color       String   @default("#007ACC")
  ownerId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  tasks Task[]
  memberships ProjectMember[]
  invites InviteToken[]

  @@index([ownerId])
}

model ProjectMember {
  id        String      @id @default(cuid())
  projectId String
  userId    String
  role      ProjectRole @default(READ_WRITE)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  type        WorkItemType @default(TASK)
  parentId    String?
  status      TaskStatus @default(BACKLOG)
  priority    Priority?
  dueDate     DateTime?
  position    Float      @default(1000)
  labels      String[]
  projectId   String
  creatorId   String
  assigneeId  String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator     User         @relation("TaskCreator", fields: [creatorId], references: [id])
  assignee    User?        @relation("TaskAssignee", fields: [assigneeId], references: [id])
  parent      Task?        @relation("TaskHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    Task[]       @relation("TaskHierarchy")
  attachments Attachment[]

  @@index([projectId])
  @@index([status])
  @@index([projectId, status])
  @@index([projectId, parentId])
  @@index([projectId, type])
}

model Attachment {
  id        String   @id @default(cuid())
  taskId    String
  filename  String
  url       String
  size      Int
  mimeType  String?
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
}
